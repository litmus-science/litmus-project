# Litmus Science Platform - Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED - Security
# =============================================================================

# JWT signing key - MUST be set in production (generate with: openssl rand -hex 32)
LITMUS_SECRET_KEY=your-secure-random-key-here

# =============================================================================
# REQUIRED - Database
# =============================================================================

# Database connection URL
# Development (SQLite): sqlite+aiosqlite:///./litmus.db
# Production (PostgreSQL): postgresql+asyncpg://user:password@host:5432/litmus
# Railway: Use ${{Postgres.DATABASE_URL}} and replace postgresql:// with postgresql+asyncpg://
LITMUS_DATABASE_URL=sqlite+aiosqlite:///./litmus.db

# =============================================================================
# OPTIONAL - CORS
# =============================================================================

# Comma-separated list of allowed origins for CORS
# Leave empty to use defaults (litmus.science domains)
# Example: https://app.example.com,https://admin.example.com
LITMUS_CORS_ORIGINS=

# =============================================================================
# OPTIONAL - Debug Mode
# =============================================================================

# Enable debug mode (enables SQL logging, localhost CORS, etc.)
# WARNING: Never enable in production
LITMUS_DEBUG=false

# =============================================================================
# OPTIONAL - File Storage (for production)
# =============================================================================

# AWS S3 or compatible storage
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=litmus-uploads
# AWS_S3_REGION=us-east-1

# Or Google Cloud Storage
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCS_BUCKET=litmus-uploads

# =============================================================================
# OPTIONAL - Email/Notifications (for production)
# =============================================================================

# SMTP settings for email notifications
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@litmus.science

# =============================================================================
# OPTIONAL - Monitoring (for production)
# =============================================================================

# Sentry DSN for error tracking
# SENTRY_DSN=

# =============================================================================
# OPTIONAL - Rate Limiting (for production with Redis)
# =============================================================================

# Redis URL for distributed rate limiting
# REDIS_URL=redis://localhost:6379/0
